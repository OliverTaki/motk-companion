{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:motk:schema:identity:v1",
  "title": "MOTK Identity Context",
  "type": "object",
  "required": ["projectId"],
  "additionalProperties": false,
  "properties": {
    "projectId": { "$ref": "#/$defs/id" },
    "shotId": { "$ref": "#/$defs/id" },
    "assetId": { "$ref": "#/$defs/id" },
    "taskId": { "$ref": "#/$defs/id" },
    "memberId": { "$ref": "#/$defs/id" },
    "fieldId": { "$ref": "#/$defs/id" },
    "take": { "type": "integer", "minimum": 1 }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$" }
  }
}
