{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/motk/recipe.schema.json",
  "title": "MOTK Companion Recipe",
  "type": "object",
  "required": ["recipe", "version", "on", "context", "steps"],
  "additionalProperties": false,
  "properties": {
    "recipe": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "version": { "type": "integer", "minimum": 1 },
    "on": { "type": "object", "required": ["event"], "additionalProperties": false, "properties": { "event": { "type": "string" } } },
    "context": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "steps": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/step" } }
  },
  "$defs": {
    "step": {
      "type": "object", "required": ["id", "uses"], "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "uses": { "enum": ["sequence.validate", "encode.ffmpeg", "file.copy", "file.mirror", "upload.enqueue", "motk.version.register", "motk.sheet.update", "playout.assembly.invalidate", "bridge.cmd", "gate.manual", "run.cli"] },
        "needs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "with": { "type": "object" },
        "retries": { "type": "integer", "minimum": 0, "maximum": 10 }
      }
    }
  }
}
