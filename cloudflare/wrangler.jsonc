{
  "$schema": "../../../../node_modules/wrangler/config-schema.json",
  "name": "motk-companion-development",
  "main": "src/worker.mjs",
  "compatibility_date": "2026-07-13",
  "workers_dev": true,
  "preview_urls": false,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "observability": {
    "enabled": false
  },
  "vars": {
    "MOTK_ENVIRONMENT": "development"
  }
}
