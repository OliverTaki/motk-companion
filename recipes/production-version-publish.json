{
  "recipe": "production-version-publish",
  "version": 1,
  "on": { "event": "manual" },
  "context": ["projectId", "shotId", "take", "versionId", "kind", "sourceFile", "durationFrames", "checksum"],
  "steps": [
    { "id": "register", "uses": "motk.version.register", "with": { "data": { "version_id": "{versionId}", "shot_id": "{shotId}", "take": "{take}", "kind": "{kind}", "file_ref": "{sourceFile}", "duration_frames": "{durationFrames}", "checksum": "{checksum}" } } }
  ]
}
